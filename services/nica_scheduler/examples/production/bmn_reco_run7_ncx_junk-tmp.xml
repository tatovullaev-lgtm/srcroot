<jobs batch="sge">
 <job name="bmn_reco">
  <macro path="$VMCWORKDIR/macro/run/run_reco_bmn.C" start_event="0" event_count="0">
   <file input="/junk/${user}/digi/2001-2212_Test/*" output="/junk/${user}/dst/run7/2001-2212_Test/bmn_run${last_number}_dst.root">
    <put command="xrdcp -f -p -N" directory="${batch_temp_dir}/"/>
    <get command="xrdcp -f -p -N" directory="${batch_temp_dir}/"/>
   </file>
   <file input="/junk/${user}/digi/3590-4707_BMN_Argon/*" output="/junk/${user}/dst/run7/3590-4707_BMN_Argon/bmn_run${last_number}_dst.root">
    <put command="xrdcp -f -p -N" directory="${batch_temp_dir}/"/>
    <get command="xrdcp -f -p -N" directory="${batch_temp_dir}/"/>
   </file>
   <file input="/junk/${user}/digi/4720-5186_BMN_Krypton/*" output="/junk/${user}/dst/run7/4720-5186_BMN_Krypton/bmn_run${last_number}_dst.root">
    <put command="xrdcp -f -p -N" directory="${batch_temp_dir}/"/>
    <get command="xrdcp -f -p -N" directory="${batch_temp_dir}/"/>
   </file>
  </macro>
  <run mode="global" count="80" config="/cvmfs/bmn.jinr.ru/config/x86_64-centos7/cluster_config.sh,/junk/$USER/bmnroot/build/config.sh"/>
 </job>
 <job name="src_reco">
  <macro path="$VMCWORKDIR/macro/run/run_reco_src.C" start_event="0" event_count="0">
   <file input="/junk/${user}/digi/2213-3588_SRC_Carbon/*" output="/junk/${user}/dst/run7/2213-3588_SRC_Carbon/bmn_run${last_number}_dst.root">
    <put command="xrdcp -f -p -N" directory="${batch_temp_dir}/"/>
    <get command="xrdcp -f -p -N" directory="${batch_temp_dir}/"/>
   </file>
  </macro>
  <run mode="global" count="40" config="/cvmfs/bmn.jinr.ru/config/x86_64-centos7/cluster_config.sh,/lhep/users/$USER/bmnroot/build/config.sh"/>
 </job>
</jobs>
